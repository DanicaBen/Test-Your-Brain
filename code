<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TEST YOUR BRAIN</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">

    <h1>🧠 TEST YOUR BRAIN 🧠</h1>
    <div class="tagline">Are You Ready To Challenge Your Mind?</div>

    <span class="brainFloat">🧠</span>
    <span class="brainFloat">⚡</span>
    <span class="brainFloat">🎯</span>

    <div id="profileSection" class="form-box">
        <input type="text" id="username" placeholder="👤 Enter Your Name"><br>
        <input type="email" id="email" placeholder="📧 Enter Your Email"><br>

        <select id="gender" onchange="generateAvatar()">
            <option value="">Select Gender</option>
            <option value="male">Male Gamer</option>
            <option value="female">Female Gamer</option>
        </select>

        <div id="avatar">🙂</div>

        <button id="startBtn" onclick="startQuizApp()">🚀 START THE CHALLENGE</button>
    </div>

    <div id="quizSection">
        <h2 id="welcomeUser"></h2>
        <div id="progress"></div>
        <div id="timer"></div>
        <h3 id="question"></h3>
        <div id="options"></div>
        <div id="message"></div>
        <div id="result"></div>
        <div id="celebrate"></div>
        <button onclick="restartQuiz()" id="startBtn">Play Again</button>
    </div>

</div>

<script src="script.js"></script>
</body>
</html>
